# observatory — broker credentials for LIVE mode. Copy to `.env` (gitignored) and
# fill in. NEVER commit real creds — this is a public repo.
#
#   cp .env.example .env  &&  $EDITOR .env
#
# Or export them in the environment. For a broker-free run use `observatory --demo`.
SMOL_MQTT_HOST=10.0.6.108
SMOL_MQTT_PORT=1883
SMOL_MQTT_USER=
SMOL_MQTT_PASS=
