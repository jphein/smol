# meshscope broker configuration — copy to `.env` and fill in.
# The .env file is git-ignored; NEVER commit real credentials.
#
# The real values are the Mosquitto (Home Assistant add-on) broker on the boards'
# own VLAN. Point SMOL_MQTT_HOST at the HA VM's leg on that subnet (the same leg
# the gateway firmware targets — see docs/protocol.md "MQTT burst"). Ask team-lead
# for the address + credentials if you don't have them.

# Broker host. Accepts "host" or "host:port" (port defaults to 1883).
# The real leg address is deliberately NOT committed (it lives only in the firmware's
# git-ignored secrets.rs). Replace this documentation placeholder (RFC 5737 TEST-NET)
# with the HA Mosquitto leg on the boards' VLAN — ask team-lead if you don't have it.
SMOL_MQTT_HOST=192.0.2.10

# Broker port (optional; overridden by a :port in SMOL_MQTT_HOST).
SMOL_MQTT_PORT=1883

# Credentials (Mosquitto anonymous auth is OFF; username is per docs/protocol.md).
SMOL_MQTT_USER=jp
SMOL_MQTT_PASS=CHANGEME
