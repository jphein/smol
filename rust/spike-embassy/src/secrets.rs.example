//! WiFi credentials for the Embassy spike's assoc+SNTP task.
//!
//!   cp src/secrets.rs.example src/secrets.rs   # then edit with real values
//!
//! `src/secrets.rs` is git-ignored (repo-root `.gitignore`: `**/secrets.rs`) — the repo
//! is public, NEVER commit real creds. The spike does not flash (HW-held), so these
//! values only need to make the WiFi task COMPILE; runtime use is future bench work.

pub const WIFI_SSID: &str = "YOUR_WIFI_SSID";
pub const WIFI_PASS: &str = "YOUR_WIFI_PASSWORD";
