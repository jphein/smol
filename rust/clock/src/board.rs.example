//! Per-board configuration TEMPLATE (issue #19) — copy to `board.rs` on a fresh
//! clone, BEFORE the first build:
//!
//! ```bash
//! cp src/board.rs.example src/board.rs   # then set NODE_ID (+ DEFAULT_APP if desired)
//! ```
//!
//! `board.rs` is git-ignored (`.gitignore`: `**/board.rs`) — NOT because it is
//! secret (it is IDENTITY/CONFIG, deliberately distinct from `secrets.rs`, which
//! holds WiFi/MQTT credentials) but so a per-board build dirties NO tracked file:
//! every board's embedded git version stamp then stays clean (that was #19's wart —
//! editing `NODE_ID` in the tracked `main.rs` made each board's stamp read "dirty").
//! EVERY build (even the default, no-feature build) needs this file — `NODE_ID`
//! feeds the node's name in all builds — so the `cp` is the first fresh-clone step.

use crate::app::AppKind;

/// This unit's logical short id — the SINGLE source of truth for the id embedded in
/// HELLO/ACK/BEACON/TIME frames and this node's magical name
/// (`net::names::name_for_id`). Give each physical board a DISTINCT value (we flashed
/// 7 / 8 / 9). Changing it changes BOTH the on-wire id and the displayed name (the
/// name is *derived* from the id and is never itself transmitted).
///
/// **Per-board builds without hand-editing (#42):** pass `SMOL_NODE_ID=<n>` at build
/// time — e.g. `SMOL_NODE_ID=8 cargo build --release --features espnow` — which
/// overrides the fallback below (build.rs threads the env; see its doc). This guards
/// the one-image-to-many flash that collides ids (the whole fleet defaulting to 7).
/// The literal is only the fallback when `SMOL_NODE_ID` is unset.
pub const NODE_ID: u8 = match option_env!("SMOL_NODE_ID") {
    Some(s) => parse_node_id(s),
    None => 7, // fallback — prefer `SMOL_NODE_ID=<n>` for distinct per-board images
};

/// Const-parse `SMOL_NODE_ID` (decimal `0..=255`) at compile time. A non-numeric,
/// empty, or out-of-range value **fails the build** — a deliberate guard: a build
/// error is far better than a silently-wrong id colliding on the wire.
const fn parse_node_id(s: &str) -> u8 {
    let b = s.as_bytes();
    assert!(!b.is_empty(), "SMOL_NODE_ID must not be empty");
    let mut n: u16 = 0;
    let mut i = 0;
    while i < b.len() {
        let d = b[i];
        assert!(d >= b'0' && d <= b'9', "SMOL_NODE_ID must be a decimal number");
        n = n * 10 + (d - b'0') as u16;
        assert!(n <= 255, "SMOL_NODE_ID must be in 0..=255");
        i += 1;
    }
    n as u8
}

/// The screen this board enters at BOOT instead of the Home menu (issue #18).
/// Valid values, by the feature tier the firmware is built with:
///   * always:              `AppKind::Menu` · `AppKind::Clock` · `AppKind::Snake` · `AppKind::About`
///   * `--features wifi`:   + `AppKind::Batt` · `AppKind::Grid`
///   * `--features espnow`: + `AppKind::Bench` · `AppKind::MeshSnake`
///
/// `AppKind::Menu` (the default) boots straight to the Home menu — the historical
/// behaviour. A long press always returns to the Menu from any screen, so a
/// non-menu default never traps the UI. Setting a variant the build does NOT define
/// is a compile error (e.g. `Grid` exists only in wifi/espnow builds).
pub const DEFAULT_APP: AppKind = AppKind::Menu;

/// The PAGE within [`DEFAULT_APP`] to show at boot — so a board can boot straight
/// into a screen's secondary page. `0` = the screen's normal first page. Applies
/// ONLY to the boot default; screens entered via the Menu always start at page 0.
/// Out-of-range clamps to page 0 (a screen with fewer pages ignores it). Page map:
///   * Batt: 0 = voltage overview; 1..N = one BIG page per detail segment (48V SOC%, HV SOC%, charge A), skips blanks.
///   * Grid: 0 = breakdown (total / L1 / L2); 1 = BIG total power (full window).
///   * Clock / Snake / Bench / MeshSnake / About / Menu: no pages → ignored.
pub const DEFAULT_PAGE: u8 = 0;

/// #13 MESH-TEST rig (`--features mesh-test` ONLY): the MACs this board pretends it
/// CANNOT hear. Inbound frames whose source MAC is in this list are silently dropped at
/// the very top of `RadioManager::service()` — faithfully simulating "out of RF range" so
/// the 3-board fleet forces a 2-hop topology (G→R→F) to validate routed multi-hop without
/// physical RF attenuation (see `scratch/smol-dreamteam/13-rig-design.md`). Empty = normal.
///
/// TEST SCAFFOLDING, per-board (like `NODE_ID`): to force `F` deaf to gateway `G`, set this
/// on board `F`'s git-ignored `board.rs` to `[Some(<G's MAC>), None, None, None]`, and the
/// reciprocal on `G`. Read each board's MAC off its Bench screen / serial. DIAG surfaces
/// `deaf=<n>` / `ddrops=<n>` so a leftover entry is visible in HA — clear it by re-flashing
/// with an empty list. A production (non-`mesh-test`) build has NO deaf field or hook at all,
/// so it can never be made deaf. NEVER commit real MACs — `board.rs` is git-ignored; this
/// tracked template stays empty.
///
/// Example (board F deaf to gateway G at 24:6f:28:aa:bb:cc):
/// ```ignore
/// pub const DEAF_MACS: [Option<[u8; 6]>; 4] =
///     [Some([0x24, 0x6f, 0x28, 0xaa, 0xbb, 0xcc]), None, None, None];
/// ```
#[cfg(feature = "mesh-test")]
pub const DEAF_MACS: [Option<[u8; 6]>; 4] = [None; 4];
